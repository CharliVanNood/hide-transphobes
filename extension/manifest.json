{
    "manifest_version": 3,
    "name": "Hide Transphobes",
    "version": "1.0",

    "permissions": [],

    "host_permissions": [
        "https://raw.githubusercontent.com/*"
    ],

    "content_scripts": [
        {
        "matches": [
            "https://x.com/*",
            "https://twitter.com/*"
        ],
        "js": ["content.js"]
        }
    ]
}